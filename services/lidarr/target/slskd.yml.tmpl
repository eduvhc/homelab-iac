# slskd configuration. Rendered by the sync engine via envsubst, then
# slskd itself expands ${SLSKD_API_KEY} at boot from EnvironmentFile=
# (separate substitution pass — central sops keys are baked in by the
# sync engine, LXC-local random secrets stay in the LXC).
#
# Sync-engine envsubst (services/lidarr/sync.yaml → envsubst:):
#   ${SOULSEEK_USERNAME}, ${SOULSEEK_PASSWORD}  — central sops, user-set
#
# Resolved by slskd at boot (NOT by the sync engine):
#   ${SLSKD_API_KEY}                             — random_secrets, LXC-local
#
# Schema validated against references/slskd/config/slskd.example.yml.

soulseek:
  username: ${SOULSEEK_USERNAME}
  password: ${SOULSEEK_PASSWORD}
  description: |
    Personal homelab — slskd. Sharing back what I download.

shares:
  directories:
    # Required by Soulseek etiquette — share at least the music library so
    # we contribute back to the network.
    - /srv/media/music

directories:
  incomplete: /var/lib/slskd/incomplete
  downloads: /srv/media/_incoming

# Transfers: relying on slskd defaults (upload.slots=20, download.slots=500,
# download.retry.attempts=3). See references/slskd/config/slskd.example.yml
# lines 57–82 if tuning is ever needed.

web:
  port: 5030
  url_base: /
  authentication:
    # Web UI auth delegated to Authelia at the gateway. slskd's own
    # username/password login is disabled — the LXC is unreachable from
    # the LAN except via Caddy's forward_auth. API key auth (used by
    # Tubifarry from localhost) stays active even when disabled=true.
    disabled: true
    api_keys:
      tubifarry_key:
        key: ${SLSKD_API_KEY}
        role: readwrite
        cidr: 127.0.0.1/32

flags:
  no_logo: true
