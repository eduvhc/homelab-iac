# Soularr configuration. Rendered at slskd unit ExecStartPre via envsubst
# against /etc/lidarr-stack/secrets.env, NOT by the central sync engine
# (those API keys are LXC-local random_secrets, never leave the host).
#
# Resolved env vars: ${LIDARR_API_KEY}, ${SLSKD_API_KEY}
#
# Adjust thresholds/quality in the [Release Settings] / [Search Settings]
# blocks via the Lidarr UI rather than here — soularr just honors what
# Lidarr already classifies as wanted.

[Lidarr]
api_key = ${LIDARR_API_KEY}
host_url = http://127.0.0.1:8686
download_dir = /srv/media/_incoming
disable_sync = False

[Slskd]
api_key = ${SLSKD_API_KEY}
host_url = http://127.0.0.1:5030
url_base = /
download_dir = /srv/media/_incoming
delete_searches = True
stalled_timeout = 3600
remote_queue_timeout = 1800

[Release Settings]
allowed_countries = US, UK, EU, XW, XE
formats = FLAC, MP3
use_most_common_tracknum = True
allow_multi_disc = True
accept_missing_album = False

[Search Settings]
search_timeout = 5000
maximum_peer_queue = 50
allowed_filetypes = flac,mp3
ignored_users =
search_for_tracks = True
remove_wanted_on_failure = False
title_blacklist =
desired_match = 1.0
desired_match_step_down = 0.05

[Download Settings]
remove_special_characters = False
allowed_filetypes = flac,mp3

[Logging]
level = INFO
format = [%%(asctime)s] [%%(levelname)s] %%(message)s
datefmt = %%Y-%%m-%%d %%H:%%M:%%S
