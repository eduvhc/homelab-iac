# Navidrome configuration. Rendered by sync.sh via envsubst with:
#   $IP_GATEWAY  — only IP allowed to inject Remote-* identity headers
# Everything else is a static, declarative default.
#
# Auth: reverse-proxy. Authelia (via Caddy on gateway) sends Remote-User /
# Remote-Email / Remote-Name. Navidrome auto-provisions the user on first
# request. Subsonic API clients (iOS/Mac apps) use per-user generated
# passwords from the web UI — that flow is unaffected by reverse-proxy auth.

# MusicFolder seeds "Library 1" on first launch. Additional libraries
# (e.g. "YouTube" → /var/lib/navidrome/media/youtube) are added via the
# web UI: Settings → Libraries → +. This is a one-time per-deploy step —
# Navidrome does not yet support declaring extra libraries via config.
MusicFolder = "/var/lib/navidrome/media/music"
DataFolder  = "/var/lib/navidrome"
Address     = "0.0.0.0"
Port        = 4533
LogLevel    = "info"

# Reverse-proxy auth — only accept identity headers from the gateway LXC.
# ND_REVERSEPROXYUSERHEADER defaults to "Remote-User" (Authelia's header).
ReverseProxyWhitelist  = "${IP_GATEWAY}/32"
ReverseProxyUserHeader = "Remote-User"

# Disable the default admin signup flow — auth is delegated to Authelia.
EnableUserEditing = false

# DB backups are handled by services/navidrome/backup-sqlite.sh (cron-driven
# from ops), following the same pattern as Authelia and Coolify. See
# docs/backups.md → "Inner backup pattern". Navidrome's own [Backup] block
# is intentionally NOT used — schedule + retention live in git, not in
# this toml.

# Scanner: watch the library for changes (inotify) on top of the periodic scan.
[Scanner]
Schedule = "@every 6h"
