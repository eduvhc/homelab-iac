theme: dark
server:
  address: tcp://0.0.0.0:9091
log:
  level: info
totp:
  issuer: ${HOMELAB_DOMAIN}
authentication_backend:
  password_reset:
    disable: true
  file:
    path: /etc/authelia/users_database.yml
    watch: true
session:
  cookies:
  - domain: ${HOMELAB_DOMAIN}
    authelia_url: https://auth.${HOMELAB_DOMAIN}
storage:
  local:
    path: /var/lib/authelia/db.sqlite3
notifier:
  filesystem:
    filename: /var/lib/authelia/notifications.txt
access_control:
  default_policy: deny
  rules:
  - domain:
    - auth.${HOMELAB_DOMAIN}
    policy: bypass
  - domain:
    - '*.${HOMELAB_DOMAIN}'
    policy: one_factor
identity_providers:
  oidc:
    jwks:
    - key_id: main
      algorithm: RS256
      use: sig
      key: |
        {{- fileContent "/etc/authelia/oidc-private.pem" | nindent 8 }}
    # 4.39 narrowed default ID Token claims to the spec minimum; clients that
    # read profile/email from the ID Token (rather than /userinfo) now see less
    # than they did on 4.38. Hydrate them explicitly so Coolify keeps working.
    claims_policies:
      default:
        id_token:
        - email
        - email_verified
        - name
        - preferred_username
    clients:
    - client_id: coolify
      client_name: Coolify
      token_endpoint_auth_method: client_secret_post
      client_secret: $pbkdf2-sha512$310000$1dV1QB3D/YeONDS0mvQPnw$K6ro1bSsztpEUxdwit./VoeqbkD.Ns3rfGeXP8ArPDJoybY4hhY9nomfUZKOOXfV0FMB.JlAqwv3ZWGhFuVGcw
      public: false
      authorization_policy: one_factor
      claims_policy: default
      require_pkce: true
      pkce_challenge_method: S256
      redirect_uris:
      - https://coolify.${HOMELAB_DOMAIN}/auth/oidc/callback
      scopes:
      - openid
      - profile
      - email
      userinfo_signed_response_alg: none
