{
    email eduardoferdcarvalho@gmail.com
    # Behind cloudflared tunnel which terminates TLS at CF edge; serve plain HTTP internally
    auto_https off
    servers {
        # Both cloudflared connectors (HA): coolify LXC + runner LXC. Without
        # the runner here, Authelia rejects forward_auth from connector 210
        # because X-Forwarded-Proto isn't trusted → "insecure scheme 'http'".
        trusted_proxies static ${IP_COOLIFY} ${IP_RUNNER} 127.0.0.1
    }
    # Default access log for all sites. zstd rolling added in Caddy 2.11
    # (roll_gzip is deprecated, slated for removal).
    log default {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
            roll_keep_for 720h
            roll_compression zstd
        }
        format json
    }
}

# Shared snippet for Authelia-protected services.
# Explicitly strip client-supplied identity headers before forward_auth runs.
# Caddy >=2.11.2 fixes GHSA-7r4p-vjf4-gxv4 (CVE-2026-30851) where copy_headers
# only emits a conditional `set` on the auth response, leaving client-injected
# values intact when the auth service omits the header. Belt-and-suspenders.
(authelia) {
    forward_auth localhost:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Email Remote-Name
        header_up -Remote-User
        header_up -Remote-Groups
        header_up -Remote-Email
        header_up -Remote-Name
    }
}

# Authelia UI itself - no forward-auth (login page must be reachable)
auth.${HOMELAB_DOMAIN}:80 {
    reverse_proxy localhost:9091
}

# AdGuard admin UI - protected
adguard.${HOMELAB_DOMAIN}:80 {
    import authelia
    reverse_proxy http://${IP_ADGUARD}:3000
}

# Navidrome (music server) - protected by reverse-proxy auth.
# Authelia's Remote-User header reaches Navidrome via the forward_auth
# response copy_headers in the (authelia) snippet. Navidrome trusts only
# the gateway IP (see services/navidrome/navidrome.toml.tmpl
# → ReverseProxyWhitelist).
music.${HOMELAB_DOMAIN}:80 {
    import authelia
    reverse_proxy http://${IP_NAVIDROME}:4533
}

# Lidarr (music library mgmt) - protected. Lidarr's own UI auth is set to
# External in services/lidarr/bootstrap.yaml → config.xml; Authelia is the
# only gate.
lidarr.${HOMELAB_DOMAIN}:80 {
    import authelia
    reverse_proxy http://${IP_LIDARR}:8686
}

# slskd (Soulseek daemon) - protected. slskd's own auth is disabled
# (services/lidarr/target/slskd.yml.tmpl → web.authentication.disabled).
slskd.${HOMELAB_DOMAIN}:80 {
    import authelia
    reverse_proxy http://${IP_LIDARR}:5030
}
