# Copy to iac/.envrc on the ops LXC. Both stacks share it: one `source`
# covers infra + platform. .envrc is gitignored — never commit it.
#
# Rule of thumb:
#   - iac/secrets.sops.yaml = genuine secrets (encrypted, committed)
#   - this file              = identifiers + non-secret config
#   - Coolify UI env vars    = app-runtime secrets (per deployed app)

# ─── Identity (non-secret config; safe values committed in .envrc.example) ──
export R2_ACCOUNT_ID="REPLACE_WITH_CF_ACCOUNT_ID"
export IEDORA_ADMIN_NAME="REPLACE_WITH_DISPLAY_NAME"
export IEDORA_ADMIN_EMAIL="REPLACE_WITH_EMAIL"

# NTFY_TOPIC: topic slug for ntfy.sh drift alerts. Not secret per se
# (threat model = spam); set after first tools/seed-secrets.sh run prints one.
export NTFY_TOPIC="REPLACE_WITH_NTFY_TOPIC"

# ─── Secrets (decrypted on-demand from iac/secrets.sops.yaml via age) ───────
# Each line becomes an env var; consumers read $TOFU_STATE_PASSPHRASE,
# $CLOUDFLARE_API_TOKEN, etc. directly. Requires sops + age installed and
# the age private key at ~/.config/sops/age/keys.txt.
# Path resolves relative to this file (BASH_SOURCE), so it works from any cwd.
_envrc_dir="${BASH_SOURCE[0]%/*}"
while IFS='=' read -r _k _v; do
  [ -n "$_k" ] && [ "${_k#\#}" = "$_k" ] && export "$_k=$_v"
done < <(sops -d --output-type dotenv "$_envrc_dir/secrets.sops.yaml")
unset _k _v _envrc_dir

# ─── OpenTofu variable bindings (one TF_VAR_x per sensitive var declared) ──
# These map decrypted env vars → tofu's `variable "x" {}` blocks.
export TF_VAR_tf_state_passphrase="$TOFU_STATE_PASSPHRASE"
export TF_VAR_cf_api_token="$CLOUDFLARE_API_TOKEN"
export TF_VAR_pve_root_password="$PVE_ROOT_PASSWORD"
export TF_VAR_coolify_api_token="$COOLIFY_API_TOKEN"

# ─── R2 backend for tofu state (native S3 + use_lockfile, no DynamoDB) ──────
# The AWS_* names are what OpenTofu's s3 backend reads — they're not
# actually AWS credentials, they're the bucket-scoped R2 token.
export AWS_ACCESS_KEY_ID="$R2_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="$R2_SECRET_ACCESS_KEY"
export AWS_REGION=auto
export AWS_ENDPOINT_URL_S3="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"
