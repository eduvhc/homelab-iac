#!/bin/sh
# Sync homelab service configs from this repo to their LXCs.
# Usage:
#   scripts/sync                  (sync all services)
#   scripts/sync adguard          (only AdGuard)
#   scripts/sync gateway          (only Caddy + Authelia)
set -e

sync_adguard() {
    echo "==> [adguard] LXC 102 (192.168.50.30)"
    HOST="root@192.168.50.30"
    python3 -c "import yaml; yaml.safe_load(open(\"configs/adguard/AdGuardHome.yaml\"))"
    scp -q configs/adguard/AdGuardHome.yaml "$HOST:/opt/AdGuardHome/AdGuardHome.yaml"
    scp -q configs/adguard/nftables.conf    "$HOST:/etc/nftables.conf"
    ssh "$HOST" "chmod 600 /opt/AdGuardHome/AdGuardHome.yaml \
        && nft -c -f /etc/nftables.conf \
        && systemctl restart AdGuardHome nftables \
        && sleep 2 && systemctl is-active AdGuardHome nftables"
}

sync_gateway() {
    echo "==> [gateway] LXC 103 (192.168.50.40)"
    HOST="root@192.168.50.40"
    command -v caddy >/dev/null && caddy validate --config configs/gateway/Caddyfile 2>&1 | tail -3 || true
    scp -q configs/gateway/Caddyfile             "$HOST:/etc/caddy/Caddyfile"
    scp -q configs/authelia/configuration.yml    "$HOST:/etc/authelia/configuration.yml"
    scp -q configs/authelia/users_database.yml   "$HOST:/etc/authelia/users_database.yml"
    ssh "$HOST" "chown authelia:authelia /etc/authelia/*.yml \
        && chmod 640 /etc/authelia/*.yml \
        && (systemctl reload caddy 2>/dev/null || systemctl restart caddy) \
        && systemctl restart authelia \
        && sleep 2 && systemctl is-active caddy authelia"
}

case "${1:-all}" in
    adguard)  sync_adguard ;;
    gateway)  sync_gateway ;;
    all|"")   sync_adguard; sync_gateway ;;
    *) echo "Usage: $0 [adguard|gateway|all]"; exit 1 ;;
esac
